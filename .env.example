# Copy this to .env and fill in values before running docker compose up

# PostgreSQL password for the cmdb user
POSTGRES_PASSWORD=changeme

# Secret key for Flask session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
API_SECRET_KEY=changeme

# Stable unique identifier for this agent instance
# Generate once with: python -c "import uuid; print(uuid.uuid4())"
AGENT_ID=00000000-0000-0000-0000-000000000000

# Human-readable hostname for this agent (defaults to container hostname if unset)
AGENT_HOSTNAME=my-server
